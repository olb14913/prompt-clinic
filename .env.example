OPENAI_API_KEY=sk-proj
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2
NOTION_API_KEY=ntn_
NOTION_DB_ID=

# F-09 자가개선 루프 (기본 OFF — 활성화하려면 true로 변경)
# Phase 1=OpenAI 최대 3회, Phase 2=Opus 최대 3회 (하드코딩, SELF_IMPROVE_MAX_ITERS 미사용)
SELF_IMPROVE_ENABLED=true

# Opus 모델 라우팅 (ANTHROPIC_API_KEY 없으면 Phase 2 비활성화)
ANTHROPIC_API_KEY=sk-ant
ANTHROPIC_MODEL_OPUS=claude-opus-4-7

# F-16 RAG (build_index() 먼저 실행 필요)
RAG_ENABLED=true