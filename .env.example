OPENAI_API_KEY=sk-proj
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.2
NOTION_API_KEY=ntn_
NOTION_DB_ID=

# F-09 자가개선 루프 (기본 OFF — 활성화하려면 true로 변경)
# Phase 1=OpenAI 최대 3회, Phase 2=Opus 최대 3회 (하드코딩, SELF_IMPROVE_MAX_ITERS 미사용)
SELF_IMPROVE_ENABLED=true

# Opus 모델 라우팅 (ANTHROPIC_API_KEY 없으면 Phase 2 비활성화)
ANTHROPIC_API_KEY=sk-ant
ANTHROPIC_MODEL_OPUS=claude-opus-4-7

# F-16 RAG (build_index() 먼저 실행 필요)
RAG_ENABLED=true

# F-15-2 few-shot 전용 DB (good/bad 사례 자동 push)
# Notion에서 DB 생성 후 ID 입력
# NOTION_FEWSHOT_DB_ID=

# F-10-6 Notion pull-back - 레벨당 가져올 few-shot 개수 (기본 8)
# NOTION_FEWSHOT_PER_LEVEL=8

# F-10-6 Notion pull-back 활성화 여부 (true로 설정 시 Notion DB에서 few-shot 가져옴)
# NOTION_FEWSHOT_ENABLED=false

# few-shot 소스를 Notion으로 사용할지 여부
# FEWSHOT_SOURCE_NOTION=false